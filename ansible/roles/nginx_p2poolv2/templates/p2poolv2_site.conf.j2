# P2Poolv2 nginx vhost for {{ p2poolv2_nginx_site_name }} -- managed by Ansible

# Rate limiting zone (per-instance name to avoid conflicts)
limit_req_zone $binary_remote_addr zone=p2poolv2_{{ p2poolv2_nginx_site_name }}:10m rate={{ p2poolv2_nginx_rate_limit }};

server {
    listen 80;
    listen [::]:80;
    server_name {{ p2poolv2_domain }}{% for d in p2poolv2_redirect_domains %} {{ d }}{% endfor %};

{% if p2poolv2_nginx_https %}
    # Redirect all HTTP to HTTPS (certbot will manage certs)
    location / {
        return 301 https://{{ p2poolv2_domain }}$request_uri;
    }
{% else %}
    location = / {
        return 302 /dashboard;
    }

    location / {
        limit_req zone=p2poolv2_{{ p2poolv2_nginx_site_name }} burst={{ p2poolv2_nginx_rate_burst }} nodelay;
        limit_req_status 429;

{% if p2poolv2_api_auth_user is defined and p2poolv2_api_auth_pass is defined %}
        proxy_set_header Authorization "Basic {{ (p2poolv2_api_auth_user ~ ':' ~ p2poolv2_api_auth_pass) | b64encode }}";
{% endif %}

        proxy_pass http://127.0.0.1:{{ p2poolv2_api_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
{% endif %}

    access_log /var/log/nginx/p2poolv2_{{ p2poolv2_nginx_site_name }}_access.log;
    error_log /var/log/nginx/p2poolv2_{{ p2poolv2_nginx_site_name }}_error.log;
}

{% if p2poolv2_nginx_https %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ p2poolv2_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ p2poolv2_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ p2poolv2_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location = / {
        return 302 /dashboard;
    }

    location / {
        limit_req zone=p2poolv2_{{ p2poolv2_nginx_site_name }} burst={{ p2poolv2_nginx_rate_burst }} nodelay;
        limit_req_status 429;

{% if p2poolv2_api_auth_user is defined and p2poolv2_api_auth_pass is defined %}
        proxy_set_header Authorization "Basic {{ (p2poolv2_api_auth_user ~ ':' ~ p2poolv2_api_auth_pass) | b64encode }}";
{% endif %}

        proxy_pass http://127.0.0.1:{{ p2poolv2_api_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    access_log /var/log/nginx/p2poolv2_{{ p2poolv2_nginx_site_name }}_access.log;
    error_log /var/log/nginx/p2poolv2_{{ p2poolv2_nginx_site_name }}_error.log;
}

{% for d in p2poolv2_redirect_domains %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ d }};

    ssl_certificate /etc/letsencrypt/live/{{ p2poolv2_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ p2poolv2_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://{{ p2poolv2_domain }}$request_uri;
}

{% endfor %}
{% endif %}
